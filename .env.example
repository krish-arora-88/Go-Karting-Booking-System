# Copy this file to .env and fill in values for local development.
# .env is git-ignored; .env.example is committed.

# ── Backend Spring Boot ──────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=gokarting
DB_USER=app
DB_PASSWORD=secret

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_SERVERS=localhost:9092

# Must be ≥ 64 chars for HMAC-SHA-512
JWT_SECRET=change-me-in-production-this-must-be-at-least-64-characters-long!!

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ── Frontend Next.js ─────────────────────────────────────────────────
# Points the frontend to the Spring Boot API
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Docker Compose overrides (optional) ──────────────────────────────
# Uncomment to change default ports
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# KAFKA_PORT=9092
# APP_PORT=8080
# GRAFANA_PORT=3001
# PROMETHEUS_PORT=9090
